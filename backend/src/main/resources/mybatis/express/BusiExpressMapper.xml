<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.project.warehouse.mapper.BusiExpressMapper">
    
    <resultMap type="BusiExpress" id="BusiExpressResult">
        <result property="id"    column="id"    />
        <result property="name"    column="name"    />
        <result property="authorizationNo"    column="authorization_no"    />
        <result property="authorizationCode"    column="authorization_code"    />
        <result property="isEnable"    column="is_enable"    />
        <result property="apiUrl"    column="api_url"    />
        <result property="createdDate"    column="created_date"    />
        <result property="updatedDate"    column="updated_date"    />
        <result property="createdBy"    column="created_by"    />
        <result property="updatedBy"    column="updated_by"    />
        <result property="deptId"    column="dept_id"    />
    </resultMap>

    <sql id="selectBusiExpressVo">
        select id, name, authorization_no, authorization_code, is_enable, api_url, created_date, updated_date, created_by, updated_by, dept_id from busi_express
    </sql>

    <select id="selectBusiExpressList" parameterType="BusiExpress" resultMap="BusiExpressResult">
        <include refid="selectBusiExpressVo"/>
        <where>  
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="authorizationNo != null  and authorizationNo != ''"> and authorization_no = #{authorizationNo}</if>
            <if test="authorizationCode != null  and authorizationCode != ''"> and authorization_code = #{authorizationCode}</if>
            <if test="isEnable != null  and isEnable != ''"> and is_enable = #{isEnable}</if>
            <if test="apiUrl != null  and apiUrl != ''"> and api_url = #{apiUrl}</if>
            <if test="createdDate != null "> and created_date = #{createdDate}</if>
            <if test="updatedDate != null "> and updated_date = #{updatedDate}</if>
            <if test="createdBy != null  and createdBy != ''"> and created_by = #{createdBy}</if>
            <if test="updatedBy != null  and updatedBy != ''"> and updated_by = #{updatedBy}</if>
            <if test="deptId != null "> and dept_id = #{deptId}</if>
            <!-- 数据范围过滤 -->
            ${params.dataScope}
        </where>
    </select>
    
    <select id="selectBusiExpressById" parameterType="Long" resultMap="BusiExpressResult">
        <include refid="selectBusiExpressVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertBusiExpress" parameterType="BusiExpress" useGeneratedKeys="true" keyProperty="id">
        insert into busi_express
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null">name,</if>
            <if test="authorizationNo != null">authorization_no,</if>
            <if test="authorizationCode != null">authorization_code,</if>
            <if test="isEnable != null">is_enable,</if>
            <if test="apiUrl != null">api_url,</if>
            <if test="createdDate != null">created_date,</if>
            <if test="updatedDate != null">updated_date,</if>
            <if test="createdBy != null">created_by,</if>
            <if test="updatedBy != null">updated_by,</if>
            <if test="deptId != null">dept_id,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null">#{name},</if>
            <if test="authorizationNo != null">#{authorizationNo},</if>
            <if test="authorizationCode != null">#{authorizationCode},</if>
            <if test="isEnable != null">#{isEnable},</if>
            <if test="apiUrl != null">#{apiUrl},</if>
            <if test="createdDate != null">#{createdDate},</if>
            <if test="updatedDate != null">#{updatedDate},</if>
            <if test="createdBy != null">#{createdBy},</if>
            <if test="updatedBy != null">#{updatedBy},</if>
            <if test="deptId != null">#{deptId},</if>
         </trim>
    </insert>

    <update id="updateBusiExpress" parameterType="BusiExpress">
        update busi_express
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null">name = #{name},</if>
            <if test="authorizationNo != null">authorization_no = #{authorizationNo},</if>
            <if test="authorizationCode != null">authorization_code = #{authorizationCode},</if>
            <if test="isEnable != null">is_enable = #{isEnable},</if>
            <if test="apiUrl != null">api_url = #{apiUrl},</if>
            <if test="createdDate != null">created_date = #{createdDate},</if>
            <if test="updatedDate != null">updated_date = #{updatedDate},</if>
            <if test="createdBy != null">created_by = #{createdBy},</if>
            <if test="updatedBy != null">updated_by = #{updatedBy},</if>
            <if test="deptId != null">dept_id = #{deptId},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteBusiExpressById" parameterType="Long">
        delete from busi_express where id = #{id}
    </delete>

    <delete id="deleteBusiExpressByIds" parameterType="String">
        delete from busi_express where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>