<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.project.warehouse.mapper.BusiExpressCustomerMapper">
    
    <resultMap type="BusiExpressCustomer" id="BusiExpressCustomerResult">
        <result property="id"    column="id"    />
        <result property="expressId"    column="express_id"    />
        <result property="address"    column="address"    />
        <result property="addressee"    column="addressee"    />
        <result property="company"    column="company"    />
        <result property="zipCode"    column="zip_code"    />
        <result property="city"    column="city"    />
        <result property="states"    column="states"    />
        <result property="country"    column="country"    />
        <result property="tel"    column="tel"    />
        <result property="createdDate"    column="created_date"    />
        <result property="updatedDate"    column="updated_date"    />
        <result property="createdBy"    column="created_by"    />
        <result property="updatedBy"    column="updated_by"    />
        <result property="deptId"    column="dept_id"    />
    </resultMap>

    <sql id="selectBusiExpressCustomerVo">
        select id, express_id, address, addressee, company, zip_code, city, states, country, tel, created_date, updated_date, created_by, updated_by, dept_id from busi_express_customer
    </sql>

    <select id="selectBusiExpressCustomerList" parameterType="BusiExpressCustomer" resultMap="BusiExpressCustomerResult">
        <include refid="selectBusiExpressCustomerVo"/>
        <where>  
            <if test="expressId != null "> and express_id = #{expressId}</if>
            <if test="address != null  and address != ''"> and address = #{address}</if>
            <if test="addressee != null  and addressee != ''"> and addressee = #{addressee}</if>
            <if test="company != null  and company != ''"> and company = #{company}</if>
            <if test="zipCode != null  and zipCode != ''"> and zip_code = #{zipCode}</if>
            <if test="city != null  and city != ''"> and city = #{city}</if>
            <if test="states != null  and states != ''"> and states = #{states}</if>
            <if test="country != null  and country != ''"> and country = #{country}</if>
            <if test="tel != null  and tel != ''"> and tel = #{tel}</if>
            <if test="createdDate != null "> and created_date = #{createdDate}</if>
            <if test="updatedDate != null "> and updated_date = #{updatedDate}</if>
            <if test="createdBy != null  and createdBy != ''"> and created_by = #{createdBy}</if>
            <if test="updatedBy != null  and updatedBy != ''"> and updated_by = #{updatedBy}</if>
            <if test="deptId != null "> and dept_id = #{deptId}</if>
            <!-- 数据范围过滤 -->
            ${params.dataScope}
        </where>
    </select>
    
    <select id="selectBusiExpressCustomerById" parameterType="Long" resultMap="BusiExpressCustomerResult">
        <include refid="selectBusiExpressCustomerVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertBusiExpressCustomer" parameterType="BusiExpressCustomer" useGeneratedKeys="true" keyProperty="id">
        insert into busi_express_customer
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="expressId != null">express_id,</if>
            <if test="address != null">address,</if>
            <if test="addressee != null">addressee,</if>
            <if test="company != null">company,</if>
            <if test="zipCode != null">zip_code,</if>
            <if test="city != null">city,</if>
            <if test="states != null">states,</if>
            <if test="country != null">country,</if>
            <if test="tel != null">tel,</if>
            <if test="createdDate != null">created_date,</if>
            <if test="updatedDate != null">updated_date,</if>
            <if test="createdBy != null">created_by,</if>
            <if test="updatedBy != null">updated_by,</if>
            <if test="deptId != null">dept_id,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="expressId != null">#{expressId},</if>
            <if test="address != null">#{address},</if>
            <if test="addressee != null">#{addressee},</if>
            <if test="company != null">#{company},</if>
            <if test="zipCode != null">#{zipCode},</if>
            <if test="city != null">#{city},</if>
            <if test="states != null">#{states},</if>
            <if test="country != null">#{country},</if>
            <if test="tel != null">#{tel},</if>
            <if test="createdDate != null">#{createdDate},</if>
            <if test="updatedDate != null">#{updatedDate},</if>
            <if test="createdBy != null">#{createdBy},</if>
            <if test="updatedBy != null">#{updatedBy},</if>
            <if test="deptId != null">#{deptId},</if>
         </trim>
    </insert>

    <update id="updateBusiExpressCustomer" parameterType="BusiExpressCustomer">
        update busi_express_customer
        <trim prefix="SET" suffixOverrides=",">
            <if test="expressId != null">express_id = #{expressId},</if>
            <if test="address != null">address = #{address},</if>
            <if test="addressee != null">addressee = #{addressee},</if>
            <if test="company != null">company = #{company},</if>
            <if test="zipCode != null">zip_code = #{zipCode},</if>
            <if test="city != null">city = #{city},</if>
            <if test="states != null">states = #{states},</if>
            <if test="country != null">country = #{country},</if>
            <if test="tel != null">tel = #{tel},</if>
            <if test="createdDate != null">created_date = #{createdDate},</if>
            <if test="updatedDate != null">updated_date = #{updatedDate},</if>
            <if test="createdBy != null">created_by = #{createdBy},</if>
            <if test="updatedBy != null">updated_by = #{updatedBy},</if>
            <if test="deptId != null">dept_id = #{deptId},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteBusiExpressCustomerById" parameterType="Long">
        delete from busi_express_customer where id = #{id}
    </delete>

    <delete id="deleteBusiExpressCustomerByIds" parameterType="String">
        delete from busi_express_customer where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>