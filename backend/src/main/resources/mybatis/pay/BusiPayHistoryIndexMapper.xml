    </update>

    <delete id="deleteBusiPayHistoryIndexById" parameterType="Long">
        delete from busi_pay_history_index where id = #{id}
    </delete>

    <delete id="deleteBusiPayHistoryIndexByIds" parameterType="String">
        delete from busi_pay_history_index where id in 
