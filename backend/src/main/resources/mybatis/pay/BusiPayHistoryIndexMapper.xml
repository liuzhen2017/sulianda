    </sql>

    <select id="selectBusiPayHistoryIndexList" parameterType="BusiPayHistoryIndex" resultMap="BusiPayHistoryIndexResult">
        <include refid="selectBusiPayHistoryIndexVo"/>
        <where>  
            <if test="custId != null "> and cust_id = #{custId}</if>
            <if test="orderNo != null  and orderNo != ''"> and order_no = #{orderNo}</if>
            <if test="money != null "> and money = #{money}</if>
            <if test="createdDate != null "> and created_date = #{createdDate}</if>
            <if test="updatedDate != null "> and updated_date = #{updatedDate}</if>
            <if test="createdBy != null  and createdBy != ''"> and created_by = #{createdBy}</if>
            <if test="updatedBy != null  and updatedBy != ''"> and updated_by = #{updatedBy}</if>
            <if test="deptId != null "> and dept_id = #{deptId}</if>
        </where>
    </select>
    
    <select id="selectBusiPayHistoryIndexById" parameterType="Long" resultMap="BusiPayHistoryIndexResult">
        <include refid="selectBusiPayHistoryIndexVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertBusiPayHistoryIndex" parameterType="BusiPayHistoryIndex" useGeneratedKeys="true" keyProperty="id">
        insert into busi_pay_history_index
        <trim prefix="(" suffix=")" suffixOverrides=",">
