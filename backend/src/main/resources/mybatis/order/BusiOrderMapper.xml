    <!--查询报表 BEGIN-->
    <select id="queryReport" resultType="com.ruoyi.project.warehouse.output.AdminReportOutput" >
        <!-- 查询总利润，总订单数量，总运费，总打包费 -->
        SELECT COALESCE(SUM(profit_money), 0) totalProfitMoney,COUNT(0) totalOderNumber,
               COALESCE(SUM(express_money), 0) totalExpressMoney,COALESCE(SUM(package_money), 0) totalPackageMoney
        FROM busi_order
        WHERE STATUS = 5
    </select>



    <select id="queryReportHistory" resultType="com.ruoyi.project.warehouse.output.AdminReportOutput" parameterType="com.ruoyi.project.warehouse.input.QueryChartInput">
        SELECT
               SUM(profit_money) totalProfitMoney,COUNT(0) totalOderNumber,
               SUM(express_money) totalExpressMoney,SUM(package_money)  totalPackageMoney,
               DATE_FORMAT(created_date, #{dateFrom}) dateStr
        FROM busi_order
        WHERE STATUS = 5
        <if test="type == '2'">
            and DATE_FORMAT(created_date, '%Y') >= #{date}
        </if>
        <if test="type == '3'">
            and DATE_FORMAT(created_date, '%Y-%m') >= #{date}
        </if>
        GROUP BY DATE_FORMAT(created_date, #{dateFrom})
        ORDER BY DATE_FORMAT(created_date, #{dateFrom})
    </select>
    <!--查询报表 END-->

